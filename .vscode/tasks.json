{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start in dev docker",
			"type": "shell",
			"command": "docker compose -f docker-compose-dev.yml up",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"icon": {
				"id": "run"
			},
			"runOptions": {
				"instancePolicy": "terminateOldest"
			},
			"promptOnClose": false
		}
	]
}